{
  "name": "nornir",
  "description": "Nornir monorepo",
  "author": "John Conley <john.fr.conley@gmail.com>",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.31.0",
    "@chialab/esbuild-plugin-html": "^0.19.1",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dprint": "^0.54.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-turbo": "^2.9.7",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-workspaces": "^0.12.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^17.0.0",
    "plop": "^4.0.5",
    "scripts": "workspace:^",
    "syncpack": "^14.3.1",
    "ts-patch": "^4.0.1",
    "turbo": "^2.9.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": "please use pnpm",
    "pnpm": ">=6.32.4",
    "yarn": "please use pnpm"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "repository": "nrfcloud/account-service",
  "scripts": {
    "clean": "rm -rf coverage reports node_modules/.cache/turbo && pnpm clean:turbo && pnpm turbo clean:single",
    "clean:turbo": "rm -rf node_modules/.cache/turbo",
    "lint": "dprint check && eslint packages/* --no-error-on-unmatched-pattern --cache && syncpack list",
    "lint:fix": "dprint fmt && eslint packages/* --no-error-on-unmatched-pattern --fix && syncpack fix && syncpack format",
    "release": "pnpm lint && pnpm build:clean && pnpm changeset publish",
    "test": "compile:tests && jest-esm --json --outputFile=reports/report.json",
    "watch": "pnpm -r --parallel compile:single:watch"
  },
  "type": "module"
}
